# Crownroad Server Configuration
# Copy this to .env and fill in your values

# Stripe payment processing (optional — cash shop works in local mode without these)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS allowed origins (comma-separated, or * for any)
# AllowedOrigins=https://crownroad.game,https://app.crownroad.game
AllowedOrigins=*

# Database path (default: crownroad.db in working directory)
# DbPath=/data/crownroad.db
